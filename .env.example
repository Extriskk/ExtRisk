
# Database (local docker-compose)
DB_PASSWORD=changeme

# Cloud database (Render)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/ext_intel_db

# Redis (Render)
REDIS_URL=rediss://:PASSWORD@HOST:6379/0

# API Keys (comma-separated)
API_KEYS=your-api-key-here

# VirusTotal API Key
VT_API_KEY=your-vt-api-key

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
SCAN_LIMIT_PER_DAY=100