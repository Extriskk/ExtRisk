
# Database (local docker-compose)
DB_PASSWORD=changeme

# Cloud database (Render)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/ext_intel_db

# Migrate local SQLite to Postgres (one-off):
# SOURCE_DATABASE_URL=sqlite:///./api_local.db DATABASE_URL=postgresql://... python scripts/migrate_sqlite_to_postgres.py --truncate
SOURCE_DATABASE_URL=sqlite:///./api_local.db

# Redis (Render)
REDIS_URL=rediss://:PASSWORD@HOST:6379/0

# API Keys (comma-separated)
API_KEYS=your-api-key-here

# VirusTotal API Key
VT_API_KEY=your-vt-api-key

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
SCAN_LIMIT_PER_DAY=100